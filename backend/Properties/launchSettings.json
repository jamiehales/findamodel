{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "profiles": {
    "Development": {
      "commandName": "Project",
      "applicationUrl": "http://127.0.0.1:5000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Desktop": {
      "commandName": "Project",
      "applicationUrl": "http://127.0.0.1:5000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "FINDAMODEL_MODE": "desktop",
        "FINDAMODEL_URL": "http://127.0.0.1:5000",
        "FINDAMODEL_DESKTOP_SESSION_TOKEN": "dev-desktop-token",
        "FINDAMODEL_DISABLE_CORS": "true"
      }
    }
  }
}
