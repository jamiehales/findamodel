{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        // EF Core DB command logs are disabled by default. Set to "Information" to enable.
        "Microsoft.EntityFrameworkCore.Database.Command": "Fatal",
        // findamodel channels — set to "Fatal" to silence a channel entirely
        "findamodel.Config": "Information",
        "findamodel.Hull": "Information",
        "findamodel.Indexing": "Information",
        "findamodel.Loader": "Information",
        "findamodel.Models": "Information",
        "findamodel.Preview": "Information",
        "findamodel.PrintingList": "Information",
        "findamodel.Explorer": "Information",
        "findamodel.Query": "Information",
        "findamodel.Metadata": "Information",
        "findamodel.AppConfig": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Models": {
    "DirectoryPath": "\\\\behemoth\\models\\Miniatures",
    "IndexSchedule": "0 3 * * *"
  },
  "Configuration": {
    "DataPath": "../debug/data"
  },
  "Indexing": {
    "DirectoryBatchSize": 1000,
    "IndexOnStartup": false
  },
  "Preview": {
    "UseGpu": true
  }
}
