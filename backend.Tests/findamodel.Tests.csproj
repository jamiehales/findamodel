<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <!-- Required for lib3mf's autogenerated C# wrapper (uses unsafe + fixed arrays) -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.*" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="9.0.15" />
    <PackageReference Include="xunit" Version="2.9.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.*">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!-- lib3mf v2.5.0 precompiled native DLL - must sit beside the test binary at runtime.
         TargetPath flattens it from lib3mf\lib3mf.dll to the root of the output directory
         so that DllImport("lib3mf.dll") can resolve it. -->
    <None Include="lib3mf\lib3mf.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>lib3mf.dll</TargetPath>
    </None>
    <!-- Suppress nullable warnings from the autogenerated lib3mf C# wrapper (Update, not Include) -->
    <Compile Update="lib3mf\Lib3MF.cs">
      <NoWarn>CS8600;CS8603;CS8604;CS8605</NoWarn>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\backend\findamodel.csproj" />
  </ItemGroup>

</Project>
