{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/backend/findamodel.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "backend: watch",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/backend/findamodel.csproj"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "isBackground": true
    },
    {
      "label": "frontend: install",
      "type": "shell",
      "command": "yarn install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "data: clear database",
      "type": "process",
      "command": "bash",
      "args": ["-c", "rm -f debug/data/findamodel.db*"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "data: clear cache",
      "type": "process",
      "command": "bash",
      "args": ["-c", "rm -rf debug/data/cache"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "infra: seq",
      "type": "shell",
      "command": "docker run --rm --name findamodel-seq -e ACCEPT_EULA=Y -p 5341:80 datalust/seq:latest",
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "reveal": "silent"
      },
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Seq listening"
        }
      }
    },
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "yarn dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    }
  ]
}
