{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/backend/findamodel.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "backend: watch",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/backend/findamodel.csproj"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "isBackground": true
    },
    {
      "label": "frontend: install",
      "type": "shell",
      "command": "yarn install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "data: clear database",
      "type": "process",
      "command": "bash",
      "args": ["-c", "rm -f debug/data/findamodel.db*"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "data: clear cache",
      "type": "process",
      "command": "bash",
      "args": ["-c", "rm -rf debug/data/cache"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "infra: seq",
      "type": "shell",
      "command": "docker run --rm --name findamodel-seq -e ACCEPT_EULA=Y -p 5341:80 datalust/seq:latest",
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "reveal": "silent"
      },
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Seq listening"
        }
      }
    },
    {
      "label": "desktop-tauri: install",
      "type": "shell",
      "command": "yarn install",
      "options": {
        "cwd": "${workspaceFolder}/desktop-tauri"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "desktop-tauri: publish",
      "type": "shell",
      "command": "yarn build",
      "options": {
        "cwd": "${workspaceFolder}/desktop-tauri"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "desktop-tauri: build sidecar",
      "type": "shell",
      "command": "node scripts/publish-sidecar.mjs",
      "options": {
        "cwd": "${workspaceFolder}/desktop-tauri"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "desktop-tauri: tauri dev (external backend)",
      "type": "shell",
      "command": "yarn tauri dev",
      "options": {
        "cwd": "${workspaceFolder}/desktop-tauri",
        "env": {
          "FINDAMODEL_EXTERNAL_BACKEND_URL": "http://127.0.0.1:5001",
          "FINDAMODEL_EXTERNAL_BACKEND_TOKEN": "dev-desktop-token"
        }
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Finished|Running.*tauri"
        }
      }
    },
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "yarn dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    }
  ]
}
