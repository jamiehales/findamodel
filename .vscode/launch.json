{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: .NET Launch",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/backend/findamodel.csproj"
    },
    {
      "name": "Frontend: Vite Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "corepack",
      "runtimeArgs": ["yarn@1.22.22", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "serverReadyAction": {
        "pattern": "Local:.*http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Desktop: Tauri Dev",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "desktop-tauri: install",
      "runtimeExecutable": "corepack",
      "runtimeArgs": ["yarn@1.22.22", "tauri", "dev"],
      "cwd": "${workspaceFolder}/desktop-tauri",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Backend + Frontend",
      "configurations": ["Backend: .NET Launch", "Frontend: Vite Dev Server"],
      "stopAll": true
    }
  ]
}
