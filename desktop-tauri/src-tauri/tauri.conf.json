{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "findamodel",
  "version": "0.1.0",
  "identifier": "io.github.findamodel.desktop",
  "build": {
    "beforeDevCommand": "yarn --cwd ../frontend dev",
    "beforeBuildCommand": "yarn --cwd .. build:sidecar && yarn --cwd ../frontend build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "findamodel",
        "width": 1360,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/**"
    ]
  }
}
